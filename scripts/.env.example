# scripts/.env — Deployment secrets for deploy.sh
# Copy this file to scripts/.env and fill in the values.
# This file is NOT committed to git (it is gitignored).
#
# Usage:
#   cp scripts/.env.example scripts/.env
#   $EDITOR scripts/.env
#   ./scripts/deploy.sh

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Git remote URL for the initial clone (not needed after first clone)
REPO_URL=git@github.com:you/live-captions-yt.git

# HS256 signing secret for JWT session tokens.
# Generate a strong random value, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-use-a-strong-random-secret

# ---------------------------------------------------------------------------
# Optional — backend features
# ---------------------------------------------------------------------------

# Admin API key for the /keys management endpoints (disabled if unset)
ADMIN_KEY=

# Comma-separated allowed origin domains for CORS (default: app.lcyt.fi,localhost)
ALLOWED_DOMAINS=app.lcyt.fi,localhost

# Enable public free-tier key sign-up at POST /keys?freetier (default: 0)
FREE_APIKEY_ACTIVE=0

# RTMP stream relay — set to 1 to enable.
# When enabled, the backend receives RTMP streams from nginx-rtmp and forwards
# them to configured relay destinations (e.g. YouTube, Twitch).
# Setting this to 1 also installs ffmpeg inside the Docker image.
# Requires a full Docker rebuild (docker compose up --build) when toggling.
RTMP_RELAY_ACTIVE=0

# Optional: restrict /rtmp callbacks to a specific nginx-rtmp application name.
# When unset or empty, the /rtmp endpoint accepts callbacks for any application name.
# RTMP_APPLICATION=live

# Enable the /usage endpoint without admin auth (leave unset to require X-Admin-Key)
# USAGE_PUBLIC=1

# ---------------------------------------------------------------------------
# Optional — deployment tuning
# ---------------------------------------------------------------------------

# Git branch to deploy (default: main)
GIT_BRANCH=main

# Require X-Api-Key header on MCP SSE connections (default: 0)
MCP_REQUIRE_API_KEY=0

# Session idle timeout in milliseconds (default: 7200000 = 2h)
# SESSION_TTL=7200000

# Session cleanup sweep interval in milliseconds (default: 300000 = 5m)
# CLEANUP_INTERVAL=300000

# Days before revoked API keys are purged from the database (default: 30)
# REVOKED_KEY_TTL_DAYS=30

# Revoked key cleanup interval in milliseconds (default: 86400000 = 24h)
# REVOKED_KEY_CLEANUP_INTERVAL=86400000

# ---------------------------------------------------------------------------
# Optional — contact info exposed at GET /contact
# ---------------------------------------------------------------------------

# CONTACT_NAME=Your Name
# CONTACT_EMAIL=you@example.com
# CONTACT_PHONE=+1-555-0100
# CONTACT_WEBSITE=https://example.com
