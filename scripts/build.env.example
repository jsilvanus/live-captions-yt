# Build-time environment variables (example)
# These are intended to be passed as build-args or env during image/build time.
# Do NOT put real secret values here — use a secure secret manager for secrets.

# Optional apt mirror to speed up apt installs during image build
APT_MIRROR=

# Feature flags used to include optional runtime components at image build time
RTMP_RELAY_ACTIVE=0   # Set to 1 to include RTMP relay tooling/ffmpeg in the image
RADIO_ACTIVE=0        # Set to 1 to include audio-only HLS features
HLS_ACTIVE=0          # Set to 1 to include video HLS features
PREVIEW_ACTIVE=0      # Set to 1 to include preview thumbnail generation
GRAPHICS_ENABLED=0    # Set to 1 to include Chromium/Playwright for DSK renderer

# Node/Build mode
NODE_ENV=production

# Vite build-time variables (optional)
# Numeric/URL values are injected into the web bundle at build-time
VITE_BACKUP_DAYS=
VITE_SITE_URL=

# Optional (secret) API key to bake into web bundle if desired (avoid in public repos)
# secret: true
VITE_API_KEY=
