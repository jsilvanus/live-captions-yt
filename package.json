{
  "name": "live-captions-yt",
  "private": true,
  "description": "Monorepo for LCYT - Live Captions for YouTube",
  "workspaces": [
    "packages/lcyt",
    "packages/lcyt-cli",
    "packages/lcyt-backend",
    "packages/lcyt-web",
    "packages/lcyt-mcp-stdio",
    "packages/lcyt-mcp-sse",
    "packages/lcyt-site",
    "packages/production-control",
    "packages/lcyt-bridge"
  ],
  "scripts": {
    "test": "npm test --workspaces",
    "build": "npm run build -w packages/lcyt",
    "start": "npm start -w packages/lcyt-cli",
    "start:backend": "npm start -w packages/lcyt-backend",
    "web": "npm run dev -w packages/lcyt-web",
    "build:web": "npm run build -w packages/lcyt-web",
    "build:site": "npm run build:web && npm run build -w packages/lcyt-site",
    "preview:web": "npm run preview -w packages/lcyt-web",
    "screenshots": "node scripts/screenshots/capture.mjs"
  },
  "author": "Juha Itäleino <jsilvanus@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jsilvanus/live-captions-yt.git"
  },
  "bugs": {
    "url": "https://github.com/jsilvanus/live-captions-yt/issues"
  },
  "homepage": "https://github.com/jsilvanus/live-captions-yt#readme",
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
