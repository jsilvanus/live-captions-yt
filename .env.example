# ─── LCYT Backend — environment variable reference ──────────────────────────
# Copy to .env and fill in required values before starting with docker compose.
#
# Most settings below are ALSO editable at runtime from Admin → Server
# (plan_env_to_ui_settings.md) once the backend is running with admin access
# (ADMIN_KEY or an is_admin user) — see
# packages/lcyt-backend/src/settings/registry.js for the authoritative list
# of every setting, its type/default, and whether a saved value takes effect
# immediately or needs a restart (each entry's `apply` field).
#
# Precedence is env > DB (Admin → Server) > built-in default: setting a
# variable here always wins and shows as "env-locked" in the admin UI — a
# deployment opts into UI control simply by *not* setting the variable.
# Bootstrap values (ports, paths, secrets, anything executed) stay env-only
# forever and are never DB-editable; the orchestrator/worker-daemon sections
# below are separate processes with no admin UI of their own either way.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required (bootstrap — env-only, never DB-editable) ───────────────────────
JWT_SECRET=change-me-in-production
ADMIN_KEY=

# ── Application (Admin → Server → Application once this is unset) ───────────
ALLOWED_DOMAINS=app.lcyt.fi,localhost
PUBLIC_URL=https://api.example.com
FREE_APIKEY_ACTIVE=0
# Hot: toggling this in Admin → Server takes effect immediately, no restart.
RTMP_RELAY_ACTIVE=0

# ── Radio HLS source ─────────────────────────────────────────────────────────
# 'ffmpeg'   — spawn ffmpeg to produce AAC HLS segments (original behaviour)
# 'mediamtx' — MediaMTX serves HLS directly, no ffmpeg for radio
RADIO_HLS_SOURCE=mediamtx

# ── MediaMTX ─────────────────────────────────────────────────────────────────
# REST API base URL (used by NginxManager + MediaMtxClient)
MEDIAMTX_API_URL=http://mediamtx:9997
# HLS base URL proxied by nginx (used to build internal proxy_pass directives)
MEDIAMTX_HLS_BASE_URL=http://mediamtx:8080
# RTSP base URL — used by rtmp-manager to build runOnPublish fan-out read commands.
# Fan-out ffmpeg reads the processed stream from here and copies to relay targets.
MEDIAMTX_RTSP_BASE_URL=rtsp://mediamtx:8554
# RTMP base URL — where the processing ffmpeg pushes its single output back into MediaMTX.
# MediaMTX then fans out via runOnPublish instead of the ffmpeg tee muxer.
# Default: rtmp://127.0.0.1:1935 (loopback when MediaMTX runs on the same host)
MEDIAMTX_RTMP_BASE_URL=rtmp://mediamtx:1935
# Basic-auth for the MediaMTX REST API (optional; leave empty for local dev)
MEDIAMTX_API_USER=
MEDIAMTX_API_PASSWORD=
# Log level: debug | info | warn | error
MEDIAMTX_LOG_LEVEL=info

# ── NginxManager — radio proxy config ────────────────────────────────────────
# Path to the nginx include file managed by NginxManager.
# The file is written inside your nginx server { } block and maps
# public slug URLs (/r/<slug>/) to MediaMTX HLS paths without exposing API keys.
# Leave empty to serve radio HLS from the Node.js backend instead (no nginx needed).
NGINX_RADIO_CONFIG_PATH=/etc/nginx/conf.d/lcyt-radio.conf
# Command to reload nginx after writing the config
NGINX_RELOAD_CMD=nginx -s reload
# Command to test nginx config before reloading (empty = skip test)
NGINX_TEST_CMD=nginx -t
# URL prefix for public radio slug locations (default: /r)
NGINX_RADIO_PREFIX=/r

# ── ffmpeg runner ─────────────────────────────────────────────────────────────
# spawn  — use local ffmpeg binary (default, works everywhere)
# docker — launch ephemeral Docker containers per job (Phases 2–3)
# worker — delegate to Compute Orchestrator (Phase 4+)
#
# NOTE: ffmpeg is still used for DSK rendering regardless of this setting.
# For radio and HLS viewer, set RADIO_HLS_SOURCE=mediamtx to avoid ffmpeg.
FFMPEG_RUNNER=spawn
FFMPEG_IMAGE=lcyt-ffmpeg:latest
# DOCKER_HOST=http://docker-socket-proxy:2375

# ── Compute Orchestrator (Phase 4+ / worker mode) ─────────────────────────────
COMPUTE_ORCHESTRATOR_URL=http://lcyt-orchestrator:4000
BACKEND_INTERNAL_TOKEN=change-me-shared-secret
ORCHESTRATOR_FALLBACK=spawn

# ── Hetzner Cloud (burst VM autoscaling) ──────────────────────────────────────
# Required only when FFMPEG_RUNNER=worker and you want burst VMs.
# Without HETZNER_API_TOKEN, the orchestrator uses only warm-pool workers.
HETZNER_API_TOKEN=
HETZNER_NETWORK_ID=
HETZNER_SNAPSHOT_ID=
HETZNER_SERVER_TYPE_BURST=cx31
HETZNER_SERVER_TYPE_WARM=cx21
HETZNER_LOCATION=hel1
WARM_POOL_SIZE=1
BURST_COOLDOWN_MS=300000
BURST_QUEUE_LIMIT=20
MAX_CONCURRENT_BURST_CREATES=3

# ── Worker daemon ─────────────────────────────────────────────────────────────
WORKER_ID=worker-0
WORKER_MAX_JOBS=4
DSK_IMAGE=lcyt-dsk-renderer:latest

# ── Contact info (GET /contact) ───────────────────────────────────────────────
CONTACT_NAME=
CONTACT_EMAIL=
CONTACT_PHONE=
CONTACT_WEBSITE=

# ── Session tuning ────────────────────────────────────────────────────────────
SESSION_TTL=7200000
CLEANUP_INTERVAL=300000
REVOKED_KEY_TTL_DAYS=30
REVOKED_KEY_CLEANUP_INTERVAL=86400000

# ── Music detection (lcyt-music) ───────────────────────────────────────────────
# Set to 1 to mount the /music routes and allow server-side analysis to start
MUSIC_DETECTION_ACTIVE=0
# Optional external/ML classifier endpoint. When set, MusicManager POSTs raw
# PCM (as a WAV body) here and uses the returned { label, confidence } in
# place of the built-in spectral heuristic, falling back to the heuristic on
# error or timeout. Leave empty to always use the built-in heuristic.
MUSIC_CLASSIFIER_URL=
# Local nginx-rtmp base URL + app name used by the RTMP audio source
# (audioSource: 'rtmp') for both MusicManager and SttManager.
# Shared with the RTMP relay; MEDIAMTX_HLS_BASE_URL above covers the default
# 'hls' audio source for MusicManager instead.
HLS_LOCAL_RTMP=rtmp://127.0.0.1:1935
HLS_RTMP_APP=live
