# Required for production — a random secret is used if unset (tokens won't survive restarts)
JWT_SECRET=change-me

# Admin endpoints (GET/POST/PATCH/DELETE /keys) — disabled if unset
ADMIN_KEY=

# SQLite database path — defaults to ./lcyt-backend.db
DB_PATH=/data/lcyt.sqlite

# Session idle timeout in milliseconds (default: 7200000 = 2h)
SESSION_TTL=7200000

# HTTP port (default: 3000)
PORT=3000

# Optional: serve a built lcyt-web bundle from this directory
# STATIC_DIR=../lcyt-web/dist

# Enable public free-tier key sign-up at POST /keys?freetier (0 = disabled)
# Free-tier keys: 200 batches/day, 1000 batches lifetime, expires in 1 month
FREE_APIKEY_ACTIVE=0

# RTMP stream relay — set to 1 to enable.
# When enabled, the backend forwards incoming RTMP streams to configured destinations.
# Also installs ffmpeg in the Docker image (requires a Docker rebuild when toggling).
RTMP_RELAY_ACTIVE=0

# Optional: restrict /rtmp callbacks to a specific nginx-rtmp application name.
# When unset, /rtmp accepts callbacks for any application name.
# RTMP_APPLICATION=live

# Database backup — number of days to keep daily backups (0 = disabled, max 180)
# Backups are written to BACKUP_DIR/<YYYY-MM-DD>/lcyt-backend.db once per day.
BACKUP_DAYS=0
# BACKUP_DIR=/backups
