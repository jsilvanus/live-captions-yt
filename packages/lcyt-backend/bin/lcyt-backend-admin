#!/usr/bin/env node
import bcrypt from 'bcryptjs';
import {
  initDb,
  getAllKeys, getKey, createKey, revokeKey, deleteKey, renewKey, updateKey, cleanRevokedKeys,
  createUser, getUserByEmail, getUserById, updateUserPassword, getKeysByUserId,
  getAllUsers, setUserAdmin, updateUser,
  getProjectFeatures, setProjectFeature, setProjectFeatures, applyFeatureDeps,
} from '../src/db.js';

// ---------------------------------------------------------------------------
// Argument parsing helpers
// ---------------------------------------------------------------------------

function parseArgs(argv) {
  const args = { flags: {}, positional: [] };
  let i = 0;
  while (i < argv.length) {
    const arg = argv[i];
    if (arg.startsWith('--')) {
      const name = arg.slice(2);
      const next = argv[i + 1];
      if (next !== undefined && !next.startsWith('--')) {
        args.flags[name] = next;
        i += 2;
      } else {
        args.flags[name] = true;
        i++;
      }
    } else {
      args.positional.push(arg);
      i++;
    }
  }
  return args;
}

function parseLimit(val) {
  if (val === undefined) return undefined;
  if (val === 'none') return null;
  const n = parseInt(val, 10);
  return Number.isFinite(n) && n >= 0 ? n : undefined;
}

function formatDate(str) {
  if (!str) return 'never';
  return str.slice(0, 10);
}

function padEnd(str, len) {
  return String(str).padEnd(len);
}

// ---------------------------------------------------------------------------
// Output formatting
// ---------------------------------------------------------------------------

function printProjectTable(keys) {
  const header = [
    padEnd('KEY', 38),
    padEnd('OWNER', 16),
    padEnd('ACTIVE', 8),
    padEnd('EXPIRES', 14),
    padEnd('USER', 6),
    'CREATED'
  ].join(' ');

  console.log('  ' + header);

  for (const k of keys) {
    const active = k.active ? 'yes' : 'REVOKED';
    const row = [
      padEnd(k.key, 38),
      padEnd(k.owner, 16),
      padEnd(active, 8),
      padEnd(formatDate(k.expires_at), 14),
      padEnd(k.user_id ?? '—', 6),
      formatDate(k.created_at)
    ].join(' ');
    console.log('  ' + row);
  }
}

function printProject(k) {
  if (!k) {
    console.error('Project not found.');
    process.exit(1);
  }
  console.log(`key:             ${k.key}`);
  console.log(`owner:           ${k.owner}`);
  console.log(`email:           ${k.email || '—'}`);
  console.log(`user id:         ${k.user_id ?? '—'}`);
  console.log(`active:          ${k.active ? 'yes' : 'REVOKED'}`);
  console.log(`expires:         ${formatDate(k.expires_at)}`);
  console.log(`daily limit:     ${k.daily_limit ?? 'unlimited'}`);
  console.log(`lifetime limit:  ${k.lifetime_limit ?? 'unlimited'}`);
  console.log(`lifetime used:   ${k.lifetime_used ?? 0}`);
  console.log(`file saving:     ${k.backend_file_enabled ? 'enabled' : 'disabled'}`);
  console.log(`graphics:        ${k.graphics_enabled ? 'enabled' : 'disabled'}`);
  console.log(`rtmp relay:      ${k.relay_allowed ? 'allowed' : 'not allowed'}`);
  console.log(`radio:           ${k.radio_enabled ? 'enabled' : 'disabled'}`);
  console.log(`hls:             ${k.hls_enabled ? 'enabled' : 'disabled'}`);
  console.log(`cea708 delay:    ${k.cea708_delay_ms ?? 0} ms`);
  console.log(`embed CORS:      ${k.embed_cors ?? '*'}`);
  console.log(`created:         ${formatDate(k.created_at)}`);
}

function printUserTable(users) {
  const header = [
    padEnd('ID', 6),
    padEnd('EMAIL', 32),
    padEnd('NAME', 20),
    padEnd('ACTIVE', 8),
    padEnd('ADMIN', 6),
    'CREATED'
  ].join(' ');
  console.log('  ' + header);
  for (const u of users) {
    const row = [
      padEnd(u.id, 6),
      padEnd(u.email, 32),
      padEnd(u.name || '—', 20),
      padEnd(u.active ? 'yes' : 'INACTIVE', 8),
      padEnd(u.is_admin ? 'yes' : 'no', 6),
      formatDate(u.created_at)
    ].join(' ');
    console.log('  ' + row);
  }
}

function printUser(u) {
  if (!u) {
    console.error('User not found.');
    process.exit(1);
  }
  console.log(`id:              ${u.id}`);
  console.log(`email:           ${u.email}`);
  console.log(`name:            ${u.name || '—'}`);
  console.log(`active:          ${u.active ? 'yes' : 'INACTIVE'}`);
  console.log(`admin:           ${u.is_admin ? 'yes' : 'no'}`);
  console.log(`created:         ${formatDate(u.created_at)}`);
}

// ---------------------------------------------------------------------------
// User resolution helper
// ---------------------------------------------------------------------------

function resolveUser(db, ref) {
  if (!ref) {
    console.error('Error: user email or id required');
    process.exit(1);
  }
  const user = /^\d+$/.test(ref)
    ? getUserById(db, Number(ref))
    : getUserByEmail(db, ref);
  if (!user) {
    console.error(`User not found: ${ref}`);
    process.exit(1);
  }
  return user;
}

// ---------------------------------------------------------------------------
// User commands
// ---------------------------------------------------------------------------

function cmdUsersList(db) {
  const users = getAllUsers(db);
  if (users.length === 0) {
    console.log('No users found.');
    return;
  }
  printUserTable(users);
}

function cmdUsersInfo(db, positional) {
  const user = resolveUser(db, positional[2]);
  printUser(user);
  const keys = getKeysByUserId(db, user.id);
  if (keys.length === 0) {
    console.log('\n  (no projects)');
  } else {
    console.log(`\nProjects (${keys.length}):`);
    printProjectTable(keys);
  }
}

async function cmdUsersAdd(db, flags) {
  const { email, name } = flags;
  const password = flags.password;
  if (!email) {
    console.error('Error: --email is required');
    process.exit(1);
  }
  if (!password || password.length < 8) {
    console.error('Error: --password is required and must be at least 8 characters');
    process.exit(1);
  }
  if (getUserByEmail(db, email)) {
    console.error(`Error: a user with email '${email}' already exists`);
    process.exit(1);
  }
  const passwordHash = await bcrypt.hash(password, 10);
  const user = createUser(db, { email, passwordHash, name: name || null });
  console.log('Created user:');
  printUser(getUserById(db, user.id));
}

async function cmdUsersSetPassword(db, positional, flags) {
  const user = resolveUser(db, positional[2]);
  const password = flags.password;
  if (!password || password.length < 8) {
    console.error('Error: --password is required and must be at least 8 characters');
    process.exit(1);
  }
  const hash = await bcrypt.hash(password, 10);
  updateUserPassword(db, user.id, hash);
  console.log(`Password updated for user ${user.id} (${user.email})`);
}

function cmdUsersUpdate(db, positional, flags) {
  const user = resolveUser(db, positional[2]);
  const updates = {};
  if ('name' in flags) updates.name = flags.name || null;
  if ('active' in flags) updates.active = flags.active === true || flags.active === 'true';
  if (Object.keys(updates).length === 0) {
    console.error('Error: nothing to update. Use --name or --active');
    process.exit(1);
  }
  updateUser(db, user.id, updates);
  console.log('Updated user:');
  printUser(getUserById(db, user.id));
}

function cmdUsersDeactivate(db, positional) {
  const user = resolveUser(db, positional[2]);
  db.prepare('UPDATE users SET active = 0 WHERE id = ?').run(user.id);
  console.log(`Deactivated user ${user.id} (${user.email})`);
}

function cmdUsersActivate(db, positional) {
  const user = resolveUser(db, positional[2]);
  db.prepare('UPDATE users SET active = 1 WHERE id = ?').run(user.id);
  console.log(`Activated user ${user.id} (${user.email})`);
}

function cmdUsersDelete(db, positional, flags) {
  const user = resolveUser(db, positional[2]);
  const keyCount = db.prepare('SELECT COUNT(*) as n FROM api_keys WHERE user_id = ? AND active = 1').get(user.id)?.n ?? 0;
  if (keyCount > 0 && !flags.force) {
    console.error(`Error: user has ${keyCount} active project(s). Revoke them first, or use --force.`);
    process.exit(1);
  }
  db.prepare('UPDATE api_keys SET user_id = NULL WHERE user_id = ?').run(user.id);
  try { db.prepare('DELETE FROM user_features WHERE user_id = ?').run(user.id); } catch { /* table may not exist */ }
  try { db.prepare('DELETE FROM project_members WHERE user_id = ?').run(user.id); } catch { /* table may not exist */ }
  db.prepare('DELETE FROM users WHERE id = ?').run(user.id);
  console.log(`Deleted user ${user.id} (${user.email}).${keyCount > 0 ? ' Their projects have been unlinked.' : ''}`);
}

function cmdUsersGrantAdmin(db, positional) {
  const user = resolveUser(db, positional[2]);
  setUserAdmin(db, user.id, true);
  console.log(`Granted admin rights to user ${user.id} (${user.email})`);
}

function cmdUsersRevokeAdmin(db, positional) {
  const user = resolveUser(db, positional[2]);
  setUserAdmin(db, user.id, false);
  console.log(`Revoked admin rights from user ${user.id} (${user.email})`);
}

// ---------------------------------------------------------------------------
// Project commands
// ---------------------------------------------------------------------------

function cmdProjectsList(db) {
  const keys = getAllKeys(db);
  if (keys.length === 0) {
    console.log('No projects found.');
    return;
  }
  printProjectTable(keys);
}

function cmdProjectsInfo(db, positional) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  printProject(getKey(db, key));
}

function cmdProjectsAdd(db, flags) {
  const { owner, key, expires, email } = flags;
  if (!owner) {
    console.error('Error: --owner is required');
    process.exit(1);
  }

  // Resolve --user-email to a user_id if provided
  let userId = undefined;
  if (flags['user-email']) {
    const user = getUserByEmail(db, flags['user-email']);
    if (!user) {
      console.error(`Error: no user found with email '${flags['user-email']}'`);
      process.exit(1);
    }
    userId = user.id;
  } else if (flags['user-id']) {
    userId = Number(flags['user-id']);
    if (!getUserById(db, userId)) {
      console.error(`Error: no user found with id ${userId}`);
      process.exit(1);
    }
  }

  const created = createKey(db, {
    key: key || undefined,
    owner,
    email: email || undefined,
    expiresAt: expires || undefined,
    daily_limit: parseLimit(flags['daily-limit']),
    lifetime_limit: parseLimit(flags['lifetime-limit']),
    backend_file_enabled: flags['file-saving'] === true || flags['file-saving'] === 'true',
    graphics_enabled: flags['graphics'] === true || flags['graphics'] === 'true',
    relay_allowed: flags['relay'] === true || flags['relay'] === 'true',
    radio_enabled: flags['radio'] === true || flags['radio'] === 'true',
    hls_enabled: flags['hls'] === true || flags['hls'] === 'true',
    cea708_delay_ms: flags['cea708-delay'] !== undefined ? Number(flags['cea708-delay']) : undefined,
    embed_cors: flags['embed-cors'] || undefined,
    user_id: userId ?? null,
  });
  console.log('Created project:');
  printProject(created);
}

function cmdProjectsUpdate(db, positional, flags) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  if (!getKey(db, key)) {
    console.error('Project not found.');
    process.exit(1);
  }

  const updates = {};
  if (flags.owner !== undefined) updates.owner = flags.owner;
  if (flags.expires !== undefined) updates.expiresAt = flags.expires || null;
  if ('daily-limit' in flags) updates.daily_limit = parseLimit(flags['daily-limit']);
  if ('lifetime-limit' in flags) updates.lifetime_limit = parseLimit(flags['lifetime-limit']);
  if ('file-saving' in flags) updates.backend_file_enabled = flags['file-saving'] === true || flags['file-saving'] === 'true';
  if ('graphics' in flags) updates.graphics_enabled = flags['graphics'] === true || flags['graphics'] === 'true';
  if ('relay' in flags) updates.relay_allowed = flags['relay'] === true || flags['relay'] === 'true';
  if ('radio' in flags) updates.radio_enabled = flags['radio'] === true || flags['radio'] === 'true';
  if ('hls' in flags) updates.hls_enabled = flags['hls'] === true || flags['hls'] === 'true';
  if ('cea708-delay' in flags) updates.cea708_delay_ms = Number(flags['cea708-delay']);
  if ('embed-cors' in flags) updates.embed_cors = flags['embed-cors'];

  if (Object.keys(updates).length === 0) {
    console.error('Error: nothing to update. Use --owner, --expires, --daily-limit, --lifetime-limit, --file-saving, --graphics, --relay, --radio, --hls, --cea708-delay, or --embed-cors');
    process.exit(1);
  }

  updateKey(db, key, updates);
  console.log('Updated:');
  printProject(getKey(db, key));
}

function cmdProjectsRevoke(db, positional) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  const ok = revokeKey(db, key);
  if (!ok) {
    console.error('Project not found.');
    process.exit(1);
  }
  console.log(`Revoked: ${key}`);
}

function cmdProjectsActivate(db, positional) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  if (!getKey(db, key)) {
    console.error('Project not found.');
    process.exit(1);
  }
  db.prepare("UPDATE api_keys SET active = 1, revoked_at = NULL WHERE key = ?").run(key);
  console.log(`Activated: ${key}`);
}

function cmdProjectsDelete(db, positional) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  const ok = deleteKey(db, key);
  if (!ok) {
    console.error('Project not found.');
    process.exit(1);
  }
  console.log(`Deleted: ${key}`);
}

function cmdProjectsRenew(db, positional, flags) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  const { expires } = flags;
  if (!expires) {
    console.error('Error: --expires is required');
    process.exit(1);
  }
  const ok = renewKey(db, key, expires);
  if (!ok) {
    console.error('Project not found.');
    process.exit(1);
  }
  console.log('Renewed:');
  printProject(getKey(db, key));
}

function cmdProjectsClean(db, flags) {
  const days = flags.days !== undefined ? Number(flags.days) : 30;
  if (!Number.isFinite(days) || days < 0) {
    console.error('Error: --days must be a non-negative number');
    process.exit(1);
  }
  const dryRun = flags['dry-run'] === true;
  const { count } = cleanRevokedKeys(db, days, dryRun);
  if (count === 0) {
    console.log(`No revoked projects older than ${days} day(s) found.`);
  } else if (dryRun) {
    console.log(`Would purge ${count} revoked project(s) older than ${days} day(s). Re-run without --dry-run to delete.`);
  } else {
    console.log(`Purged ${count} revoked project(s) older than ${days} day(s).`);
  }
}

// ---------------------------------------------------------------------------
// Project feature commands
// ---------------------------------------------------------------------------

function cmdProjectsFeaturesList(db, positional) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  if (!getKey(db, key)) {
    console.error('Project not found.');
    process.exit(1);
  }
  const rows = getProjectFeatures(db, key);
  if (rows.length === 0) {
    console.log('No features set for this project.');
    return;
  }
  const header = [padEnd('FEATURE', 28), padEnd('ENABLED', 8), 'GRANTED AT'].join(' ');
  console.log('  ' + header);
  for (const r of rows) {
    const row = [padEnd(r.feature_code, 28), padEnd(r.enabled ? 'yes' : 'no', 8), r.granted_at || '—'].join(' ');
    console.log('  ' + row);
  }
}

function cmdProjectsFeaturesSet(db, positional) {
  const key = positional[2];
  const code = positional[3];
  const val = positional[4];
  if (!key || !code) {
    console.error('Error: key and feature-code arguments required');
    process.exit(1);
  }
  if (!getKey(db, key)) {
    console.error('Project not found.');
    process.exit(1);
  }
  const enabled = val === undefined || val === 'true' || val === '1';
  setProjectFeature(db, key, code, enabled);
  console.log(`Feature '${code}' ${enabled ? 'enabled' : 'disabled'} for project ${key}`);
}

function cmdProjectsFeaturesBatch(db, positional, flags) {
  const key = positional[2];
  if (!key) {
    console.error('Error: key argument required');
    process.exit(1);
  }
  if (!getKey(db, key)) {
    console.error('Project not found.');
    process.exit(1);
  }
  const featuresJson = flags.features;
  if (!featuresJson) {
    console.error('Error: --features <json> is required (e.g. --features \'{"ai":true,"stt":false}\')');
    process.exit(1);
  }
  let features;
  try {
    features = JSON.parse(featuresJson);
  } catch {
    console.error('Error: --features value must be valid JSON');
    process.exit(1);
  }
  const resolved = applyFeatureDeps(features);
  setProjectFeatures(db, key, resolved, 'admin');
  console.log(`Features updated for project ${key}`);
  cmdProjectsFeaturesList(db, positional);
}

// ---------------------------------------------------------------------------
// Usage
// ---------------------------------------------------------------------------

function usage() {
  console.log(`Usage: lcyt-backend-admin <command> [options]

User commands:
  users list                        List all user accounts
  users info <email|id>             Show user details and their projects
  users add --email <email> --password <password> [--name <name>]
                                    Create a new user account
  users set-password <email|id> --password <password>
                                    Reset a user's password
  users update <email|id> [--name <name>] [--active true|false]
                                    Update user fields
  users deactivate <email|id>       Disable a user account (login blocked)
  users activate <email|id>         Re-enable a disabled user account
  users delete <email|id> [--force] Delete a user (--force unlinks active projects)
  users grant-admin <email|id>      Grant admin rights to a user
  users revoke-admin <email|id>     Revoke admin rights from a user

Project commands:
  projects list                     List all projects (API keys)
  projects info <key>               Show details for a project
  projects add --owner <name> [--key <key>] [--email <email>] [--expires <date>]
      [--daily-limit <n>] [--lifetime-limit <n>] [--file-saving] [--graphics]
      [--relay] [--radio] [--hls] [--cea708-delay <ms>] [--embed-cors <origin>]
      [--user-email <email>] [--user-id <id>]
                                    Create a new project (optionally linked to a user)
  projects update <key> [--owner <name>] [--expires <date>]
      [--daily-limit <n|none>] [--lifetime-limit <n|none>]
      [--file-saving [true|false]] [--graphics [true|false]]
      [--relay [true|false]] [--radio [true|false]] [--hls [true|false]]
      [--cea708-delay <ms>] [--embed-cors <origin>]
                                    Update project fields (use 'none' to remove a limit)
  projects revoke <key>             Revoke (soft-delete) a project
  projects activate <key>           Re-activate a revoked project
  projects delete <key>             Permanently remove a project
  projects renew <key> --expires <date>
                                    Extend project expiration
  projects clean [--days 30] [--dry-run]
                                    Purge revoked projects older than N days

Project feature commands:
  projects features list <key>      List all feature flags for a project
  projects features set <key> <code> [true|false]
                                    Enable or disable a feature flag (default: enable)
  projects features batch <key> --features <json>
                                    Batch set features, e.g. --features '{"ai":true,"stt":false}'

Options:
  --db <path>    Path to the SQLite database (default: ./lcyt-backend.db or DB_PATH env var)
  --help         Show this help message
`);
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------

const parsed = parseArgs(process.argv.slice(2));
const { flags, positional } = parsed;

if (flags.help || positional.length === 0) {
  usage();
  process.exit(0);
}

const dbPath = flags.db || undefined;
const db = initDb(dbPath);

const command = positional[0];

if (command === 'users') {
  const sub = positional[1];
  switch (sub) {
    case 'list':
      cmdUsersList(db);
      break;
    case 'info':
      cmdUsersInfo(db, positional);
      break;
    case 'add':
      await cmdUsersAdd(db, flags);
      break;
    case 'set-password':
      await cmdUsersSetPassword(db, positional, flags);
      break;
    case 'update':
      cmdUsersUpdate(db, positional, flags);
      break;
    case 'deactivate':
      cmdUsersDeactivate(db, positional);
      break;
    case 'activate':
      cmdUsersActivate(db, positional);
      break;
    case 'delete':
      cmdUsersDelete(db, positional, flags);
      break;
    case 'grant-admin':
      cmdUsersGrantAdmin(db, positional);
      break;
    case 'revoke-admin':
      cmdUsersRevokeAdmin(db, positional);
      break;
    default:
      console.error(`Unknown users subcommand: ${sub || '(none)'}`);
      usage();
      process.exit(1);
  }
} else if (command === 'projects') {
  const sub = positional[1];
  if (sub === 'features') {
    const featureSub = positional[2];
    switch (featureSub) {
      case 'list':
        cmdProjectsFeaturesList(db, positional.slice(1));
        break;
      case 'set':
        cmdProjectsFeaturesSet(db, positional.slice(1));
        break;
      case 'batch':
        cmdProjectsFeaturesBatch(db, positional.slice(1), flags);
        break;
      default:
        console.error(`Unknown projects features subcommand: ${featureSub || '(none)'}`);
        usage();
        process.exit(1);
    }
  } else {
    switch (sub) {
      case 'list':
        cmdProjectsList(db);
        break;
      case 'info':
        cmdProjectsInfo(db, positional);
        break;
      case 'add':
        cmdProjectsAdd(db, flags);
        break;
      case 'update':
        cmdProjectsUpdate(db, positional, flags);
        break;
      case 'revoke':
        cmdProjectsRevoke(db, positional);
        break;
      case 'activate':
        cmdProjectsActivate(db, positional);
        break;
      case 'delete':
        cmdProjectsDelete(db, positional);
        break;
      case 'renew':
        cmdProjectsRenew(db, positional, flags);
        break;
      case 'clean':
        cmdProjectsClean(db, flags);
        break;
      default:
        console.error(`Unknown projects subcommand: ${sub || '(none)'}`);
        usage();
        process.exit(1);
    }
  }
} else {
  console.error(`Unknown command: ${command}`);
  usage();
  process.exit(1);
}

db.close();

