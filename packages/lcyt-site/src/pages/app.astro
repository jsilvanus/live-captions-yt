---
import Base from '../layouts/Base.astro';
import FreeKeyForm from '../components/FreeKeyForm.astro';
---
<Base title="App">
  <div class="app-page">
    <h1>LCYT Web App</h1>
    <p>
      The LCYT web app lets you send live captions to your YouTube Live stream directly from your browser. To use the app, you need an API key.
    </p>

    <div style="margin: 1.5rem 0;">
      <a class="btn-primary" href="https://app.lcyt.fi" target="_blank" rel="noopener noreferrer">
        Open the App →
      </a>
    </div>

    <h2 style="font-size:1.3rem;margin:1.5rem 0 0.75rem;">Get a Free API Key</h2>
    <p>
      Fill in your name and email to receive a free trial key instantly. Free keys allow up to 200 captions per day and are valid for 30 days.
    </p>

    <FreeKeyForm />

    <div style="margin-top:2.5rem;">
      <a class="btn-primary" href="https://app.lcyt.fi" target="_blank" rel="noopener noreferrer">
        Open the App →
      </a>
    </div>

    <!-- Guide section — links to the full /guide page -->
    <section class="app-guide" id="guide">
      <h2>Guide</h2>
      <p>
        The full step-by-step guide covers everything you need to get the most out of the LCYT web app.
      </p>

      <ul class="app-guide__toc">
        <li><a href="/guide#overview">Overview — what LCYT is and how it works</a></li>
        <li><a href="/guide#getting-started">Getting started — set up YouTube Live and connect</a></li>
        <li><a href="/guide#sending-captions">Sending captions — typed input, speech recognition, and file playback</a></li>
        <li><a href="/guide#caption-settings">Caption settings — STT engine, VAD, and display options</a></li>
        <li><a href="/guide#translation">Translation — real-time automatic caption translation</a></li>
        <li><a href="/guide#general-settings">General settings — connection, RTMP relay, and theme</a></li>
        <li><a href="/guide#status-actions">Status &amp; Actions — session monitoring and diagnostics</a></li>
        <li><a href="/guide#keyboard-shortcuts">Keyboard shortcuts — full shortcut reference</a></li>
      </ul>

      <div style="margin-top:1.5rem;">
        <a class="btn-primary" href="/guide">Read the full guide →</a>
      </div>
    </section>
  </div>
</Base>
