---
import Base from '../layouts/Base.astro';
---
<Base title="App">
  <div class="app-page">
    <h1>LCYT Web App</h1>
    <p>
      The LCYT web app lets you send live captions to your YouTube Live stream directly from your browser. To use the app, you need an API key from the operator.
    </p>

    <h2 style="font-size:1.3rem;margin:1.5rem 0 0.75rem;">Get an API Key</h2>
    <p>
      API keys are issued manually. Contact the operator to request access:
    </p>
    <p>
      <a href="mailto:contact@lcyt.fi" style="font-weight:600;">contact@lcyt.fi</a>
    </p>
    <p style="margin-top:1rem;font-size:0.95rem;color:#666;">
      When requesting a key, please include your name, intended use case, and estimated caption volume.
    </p>

    <div style="margin-top:2.5rem;">
      <a class="btn-primary" href="https://app.lcyt.fi" target="_blank" rel="noopener noreferrer">
        Open the App →
      </a>
    </div>
  </div>
</Base>
