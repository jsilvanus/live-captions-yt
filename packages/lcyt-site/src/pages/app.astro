---
import Base from '../layouts/Base.astro';
import FreeKeyForm from '../components/FreeKeyForm.astro';
---
<Base title="App">
  <div class="app-page">
    <h1>LCYT Web App</h1>
    <p>
      The LCYT web app lets you send live captions to your YouTube Live stream directly from your browser. To use the app, you need an API key.
    </p>

    <div style="margin: 1.5rem 0;">
      <a class="btn-primary" href="https://app.lcyt.fi" target="_blank" rel="noopener noreferrer">
        Open the App →
      </a>
    </div>

    <h2 style="font-size:1.3rem;margin:1.5rem 0 0.75rem;">Get a Free API Key</h2>
    <p>
      Fill in your name and email to receive a free trial key instantly. Free keys allow up to 200 captions per day and are valid for 30 days.
    </p>

    <FreeKeyForm />

    <div style="margin-top:2.5rem;">
      <a class="btn-primary" href="https://app.lcyt.fi" target="_blank" rel="noopener noreferrer">
        Open the App →
      </a>
    </div>

    <!-- Guide section (placeholder — will become a full help guide) -->
    <section class="app-guide" id="guide">
      <h2>Guide</h2>
      <p class="app-guide__placeholder">
        A step-by-step guide for using the LCYT web app is coming soon. It will cover setting up your YouTube Live stream, connecting with an API key, sending captions, and advanced features such as translation, RTMP relay, and keyboard shortcuts.
      </p>
    </section>
  </div>
</Base>
