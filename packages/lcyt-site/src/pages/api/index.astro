---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

const ENDPOINTS_ORDER = [
  'sessions', 'sync', 'captions', 'events',
  'keys', 'stats', 'files', 'usage', 'mic', 'health', 'contact',
];

function docLabel(id: string, title?: string): string {
  if (title) return title;
  if (id === 'README') return 'Overview';
  return id.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const allDocs = await getCollection('api');

const readme = allDocs.find(d => d.id === 'README');
const endpointDocs = ENDPOINTS_ORDER
  .map(id => allDocs.find(d => d.id === id))
  .filter(Boolean) as typeof allDocs;

const docs = [
  ...(readme ? [readme] : []),
  ...endpointDocs,
];

const rendered = await Promise.all(docs.map(doc => render(doc)));
---
<GuideLayout
  title="API Reference"
  description="HTTP API reference for the LCYT relay backend — sessions, captions, keys, stats, and more."
>
  <Fragment slot="sidebar">
    <div style="padding-left: 0.5rem;">
      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem;">API</p>

      {readme && (
        <>
          <ul style="list-style: none; margin-bottom: 1rem;">
            <li><a href={`#${readme.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">Overview</a></li>
          </ul>
          <div style="height: 1px; background: var(--border); margin-bottom: 1rem;"></div>
        </>
      )}

      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem;">Endpoints</p>
      <ul style="list-style: none;">
        {endpointDocs.map(doc => (
          <li><a href={`#${doc.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{docLabel(doc.id, doc.data.title)}</a></li>
        ))}
      </ul>
    </div>
  </Fragment>

  {docs.map((doc, i) => {
    const { Content } = rendered[i];
    return (
      <section id={doc.id.replace(/\//g, '-')}>
        <Content />
      </section>
    );
  })}
</GuideLayout>
