---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const allPosts = await getCollection('blog');
const posts = [...allPosts].sort((a, b) => b.data.date.localeCompare(a.data.date));
const sidebarItems = posts.map(p => ({
  id: p.id,
  label: p.data.title,
}));

const rendered = await Promise.all(posts.map(post => render(post)));
---
<DocsLayout title="Blog" sidebarItems={sidebarItems} sidebarHeading="Posts">
  {posts.map((post, i) => {
    const { Content } = rendered[i];
    return (
      <section id={post.id.replace(/\//g, '-')} class="doc-section blog-post">
        <div class="meta">{post.data.date}</div>
        <Content />
      </section>
    );
  })}
</DocsLayout>
