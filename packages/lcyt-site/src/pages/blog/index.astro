---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

const allPosts = await getCollection('blog');
const posts = [...allPosts].sort((a, b) => b.data.date.localeCompare(a.data.date));

const rendered = await Promise.all(posts.map(post => render(post)));
---
<GuideLayout
  title="Blog"
  description="Updates, tutorials, and insights from the LCYT team."
>
  <Fragment slot="sidebar">
    <div style="padding-left: 0.5rem;">
      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem;">Posts</p>
      <ul style="list-style: none;">
        {posts.map(post => (
          <li><a href={`#${post.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{post.data.title}</a></li>
        ))}
      </ul>
    </div>
  </Fragment>

  {posts.map((post, i) => {
    const { Content } = rendered[i];
    return (
      <section id={post.id.replace(/\//g, '-')}>
        <div style="margin-bottom: 1.5rem;">
          <p style="font-size: 0.875rem; color: var(--muted); margin: 0;">{post.data.date}{post.data.author ? ` — by ${post.data.author}` : ''}</p>
        </div>
        <Content />
      </section>
    );
  })}
</GuideLayout>
