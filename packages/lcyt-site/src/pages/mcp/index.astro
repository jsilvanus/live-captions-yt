---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const ORDER = [
  'README', 'tools', 'stdio', 'sse',
  'tools/start', 'tools/send-caption', 'tools/send-batch',
  'tools/sync-clock', 'tools/get-status', 'tools/stop',
  'tools/privacy', 'tools/privacy-deletion', 'tools/session-resources',
];

function sortDocs(docs: { id: string }[]) {
  return [...docs].sort((a, b) => {
    const ai = ORDER.indexOf(a.id);
    const bi = ORDER.indexOf(b.id);
    if (ai === -1 && bi === -1) return a.id.localeCompare(b.id);
    if (ai === -1) return 1;
    if (bi === -1) return -1;
    return ai - bi;
  });
}

function docLabel(id: string, title?: string): string {
  if (title) return title;
  if (id === 'README') return 'Overview';
  const name = id.includes('/') ? id.split('/').pop()! : id;
  return name.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const allDocs = await getCollection('mcp');
const docs = sortDocs(allDocs);
const sidebarItems = docs.map(d => ({
  id: d.id,
  label: docLabel(d.id, d.data.title),
}));

const rendered = await Promise.all(docs.map(doc => render(doc)));
---
<DocsLayout title="MCP Server" sidebarItems={sidebarItems} sidebarHeading="MCP">
  {docs.map((doc, i) => {
    const { Content } = rendered[i];
    return (
      <section id={doc.id.replace(/\//g, '-')} class="doc-section">
        <Content />
      </section>
    );
  })}
</DocsLayout>
