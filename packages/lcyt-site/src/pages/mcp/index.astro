---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

const allDocs = await getCollection('mcp');
const docs = [...allDocs].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const rendered = await Promise.all(docs.map(doc => render(doc)));
---
<GuideLayout
  title="MCP"
  description="Model Context Protocol server — integrate LCYT with AI assistants like Claude."
>
  <Fragment slot="sidebar">
    <div style="padding-left: 0.5rem;">
      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem;">MCP</p>
      <ul style="list-style: none;">
        {docs.map(doc => (
          <li><a href={`#${doc.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{doc.data.title || doc.id}</a></li>
        ))}
      </ul>
    </div>
  </Fragment>

  {docs.map((doc, i) => {
    const { Content } = rendered[i];
    return (
      <section id={doc.id.replace(/\//g, '-')}>
        <Content />
      </section>
    );
  })}
</GuideLayout>
