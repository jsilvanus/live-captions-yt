---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const TOOLS_ORDER = [
  'tools/start', 'tools/send-caption', 'tools/send-batch',
  'tools/sync-clock', 'tools/get-status', 'tools/stop',
  'tools/privacy', 'tools/privacy-deletion', 'tools/session-resources',
];

function docLabel(id: string, title?: string): string {
  if (title) return title;
  if (id === 'README') return 'Overview';
  const name = id.includes('/') ? id.split('/').pop()! : id;
  return name.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

// Use only the `mcp` collection here — other pages should use their own collections.
const allDocs = await getCollection('mcp');

function matchTarget(doc: any, target: string) {
  const last = target.split('/').pop()!.toLowerCase();
  const id = (doc.id || '').toString().toLowerCase();
  const slug = (doc.slug || '').toString().toLowerCase();
  const title = ((doc.data && doc.data.title) || '').toString().toLowerCase();
  const t = target.toLowerCase();
  if (id === t || slug === t) return true;
  if (id.endsWith('/' + t) || slug.endsWith('/' + t)) return true;
  if (id.includes(last) || slug.includes(last) || title.includes(last.replace(/-/g, ' '))) return true;
  return false;
}

// Separate docs by category (use flexible matching to handle collection prefixes)
const readme = allDocs.find(d => matchTarget(d, 'readme') || matchTarget(d, 'mcp/readme') || (d.data && d.data.title && d.data.title.toLowerCase().includes('overview'))) || allDocs[0];
const toolsIndex = allDocs.find(d => matchTarget(d, 'tools') || matchTarget(d, 'mcp/tools'));
const stdioDoc = allDocs.find(d => matchTarget(d, 'stdio') || matchTarget(d, 'mcp/stdio'));
const sseDoc = allDocs.find(d => matchTarget(d, 'sse') || matchTarget(d, 'mcp/sse'));
const toolDocs = TOOLS_ORDER
  .map(id => allDocs.find(d => matchTarget(d, id) || matchTarget(d, 'mcp/' + id)))
  .filter(Boolean) as typeof allDocs;

// Ordered list for rendering
const docs = [
  ...(readme ? [readme] : []),
  ...(toolsIndex ? [toolsIndex] : []),
  ...(stdioDoc ? [stdioDoc] : []),
  ...(sseDoc ? [sseDoc] : []),
  ...toolDocs,
];

const sidebarSections = [
  {
    items: [
      ...(readme ? [{ id: readme.id, label: 'Overview' }] : []),
      ...(toolsIndex ? [{ id: toolsIndex.id, label: 'Tools Overview' }] : []),
    ],
  },
  {
    heading: 'Transport',
    items: [
      ...(sseDoc ? [{ id: sseDoc.id, label: 'HTTP SSE' }] : []),
      ...(stdioDoc ? [{ id: stdioDoc.id, label: 'stdio (local)' }] : []),
    ],
  },
  {
    heading: 'Tools',
    items: toolDocs.map(d => ({ id: d.id, label: docLabel(d.id, d.data.title) })),
  },
];

const rendered = await Promise.all(docs.map(doc => render(doc)));
---
<DocsLayout title="MCP Server" sidebarSections={sidebarSections} sidebarHeading="MCP">
  {docs.map((doc, i) => {
    const { Content } = rendered[i];
    return (
      <section id={doc.id.replace(/\//g, '-')} class="doc-section">
        <Content />
      </section>
    );
  })}
</DocsLayout>
