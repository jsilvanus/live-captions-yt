---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import GuideHeader from '../../components/GuideHeader.astro';

const CLI_ORDER = ['full-screen', 'interactive', 'single-caption'];

const WEB_ORDER = [
  'overview',
  'getting-started',
  'sending-captions',
  'caption-settings',
  'translation',
  'general-settings',
  'status-actions',
  'keyboard-shortcuts',
  'embed',
  'minimal-backend',
  'flow',
];

function sortDocs<T extends { id: string; data: { order?: number; title?: string } }>(
  allDocs: T[],
  order: string[],
) {
  return [...allDocs].sort((a, b) => {
    const idxA = order.indexOf(a.id);
    const idxB = order.indexOf(b.id);
    const orderA = a.data.order ?? (idxA >= 0 ? idxA + 1 : 99);
    const orderB = b.data.order ?? (idxB >= 0 ? idxB + 1 : 99);
    return orderA - orderB;
  });
}

function toLabel(doc: { id: string; data: { title?: string } }) {
  return doc.data.title ?? doc.id.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const cliDocs = sortDocs(await getCollection('guide-cli'), CLI_ORDER);
const webDocs = sortDocs(await getCollection('guide-web'), WEB_ORDER);

const allSections = [
  ...cliDocs.map(d => ({ id: `cli-${d.id}`, label: toLabel(d) })),
  ...webDocs.map(d => ({ id: `web-${d.id}`, label: toLabel(d) })),
];

const sidebarSections = [
  {
    heading: 'CLI Guide',
    items: cliDocs.map(d => ({ id: `cli-${d.id}`, label: toLabel(d) })),
  },
  {
    heading: 'Web App Guide',
    items: webDocs.map(d => ({ id: `web-${d.id}`, label: toLabel(d) })),
  },
];

const cliRendered = await Promise.all(cliDocs.map(doc => render(doc)));
const webRendered = await Promise.all(webDocs.map(doc => render(doc)));
---
<DocsLayout title="Guide" sidebarSections={sidebarSections} sidebarHeading="Guide">
  <GuideHeader
    title="Complete LCYT Guide"
    subtitle="Learn how to use LCYT with both the command-line tool and the web app. Start with the overview to understand the basics, then explore the sections that match your use case."
    estimatedTime="15 min read"
    sections={allSections}
  />

  <section class="guide-section-group">
    <h2 class="section-group-title">CLI Guide</h2>
    {cliDocs.map((doc, i) => {
      const { Content } = cliRendered[i];
      return (
        <section id={`cli-${doc.id.replace(/\//g, '-')}`} class="doc-section">
          <Content />
        </section>
      );
    })}
  </section>

  <section class="guide-section-group">
    <h2 class="section-group-title">Web App Guide</h2>
    {webDocs.map((doc, i) => {
      const { Content } = webRendered[i];
      return (
        <section id={`web-${doc.id.replace(/\//g, '-')}`} class="doc-section">
          <Content />
        </section>
      );
    })}
  </section>
</DocsLayout>

<style>
  .section-group-title {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
  }

  .section-group-title:first-child {
    margin-top: 2rem;
  }
</style>
