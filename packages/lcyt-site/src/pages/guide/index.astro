---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

const CLI_ORDER = ['full-screen', 'interactive', 'single-caption'];

const WEB_ORDER = [
  'overview',
  'getting-started',
  'sending-captions',
  'caption-settings',
  'translation',
  'general-settings',
  'status-actions',
  'keyboard-shortcuts',
  'embed',
  'minimal-backend',
  'flow',
];

function sortDocs<T extends { id: string; data: { order?: number; title?: string } }>(
  allDocs: T[],
  order: string[],
) {
  return [...allDocs].sort((a, b) => {
    const idxA = order.indexOf(a.id);
    const idxB = order.indexOf(b.id);
    const orderA = a.data.order ?? (idxA >= 0 ? idxA + 1 : 99);
    const orderB = b.data.order ?? (idxB >= 0 ? idxB + 1 : 99);
    return orderA - orderB;
  });
}

function toLabel(doc: { id: string; data: { title?: string } }) {
  return doc.data.title ?? doc.id.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const cliDocs = sortDocs(await getCollection('guide-cli'), CLI_ORDER);
const webDocs = sortDocs(await getCollection('guide-web'), WEB_ORDER);

const cliRendered = await Promise.all(cliDocs.map(doc => render(doc)));
const webRendered = await Promise.all(webDocs.map(doc => render(doc)));
---
<GuideLayout
  title="Guide"
  description="Complete documentation for the LCYT web app and CLI — setup, captions, translation, shortcuts, and more."
>
  <Fragment slot="sidebar">
    <div style="padding-left: 0.5rem;">
      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem;">Guide</p>

      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; margin-top: 0.5rem;">CLI</p>
      <ul style="list-style: none; margin-bottom: 1rem;">
        {cliDocs.map(doc => (
          <li><a href={`#cli-${doc.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{toLabel(doc)}</a></li>
        ))}
      </ul>

      <div style="height: 1px; background: var(--border); margin-bottom: 1rem;"></div>

      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem;">Web App</p>
      <ul style="list-style: none;">
        {webDocs.map(doc => (
          <li><a href={`#web-${doc.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{toLabel(doc)}</a></li>
        ))}
      </ul>
    </div>
  </Fragment>

  {cliDocs.map((doc, i) => {
    const { Content } = cliRendered[i];
    return (
      <section id={`cli-${doc.id}`}>
        <Content />
      </section>
    );
  })}

  {webDocs.map((doc, i) => {
    const { Content } = webRendered[i];
    return (
      <section id={`web-${doc.id}`}>
        <Content />
      </section>
    );
  })}
</GuideLayout>
