</style>

<script>
  const container = document.querySelector<HTMLElement>('#sb-split');
  const divider = document.querySelector<HTMLElement>('#sb-divider');

  if (container && divider) {
    const panelEn = container.querySelector<HTMLElement>('.sb-panel--en');
    const panelFi = container.querySelector<HTMLElement>('.sb-panel--fi');

    if (panelEn && panelFi) {
      let pct = 50;
      let dragging = false;

      function applyPct(p: number) {
        pct = Math.max(0, Math.min(100, p));
        panelEn.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
        panelFi.style.clipPath = `inset(0 0 0 ${pct}%)`;
        divider.style.left = `${pct}%`;
        divider.setAttribute('aria-valuenow', String(Math.round(pct)));
      }

      applyPct(50);

      function getClientX(e: MouseEvent | TouchEvent): number {
        const touches = (e as TouchEvent).touches;
        return touches ? touches[0].clientX : (e as MouseEvent).clientX;
      }

      function onMove(e: MouseEvent | TouchEvent) {
        if (!dragging) return;
        e.preventDefault();
        const rect = container.getBoundingClientRect();
        applyPct(((getClientX(e) - rect.left) / rect.width) * 100);
      }

      function stopDrag() {
        dragging = false;
        document.removeEventListener('mousemove', onMove as EventListener);
        document.removeEventListener('mouseup', stopDrag);
        document.removeEventListener('touchmove', onMove as EventListener);
        document.removeEventListener('touchend', stopDrag);
      }

      divider.addEventListener('mousedown', (e) => {
        e.preventDefault();
        dragging = true;
        document.addEventListener('mousemove', onMove as EventListener);
        document.addEventListener('mouseup', stopDrag);
      });

      divider.addEventListener('touchstart', () => {
        dragging = true;
        document.addEventListener('touchmove', onMove as EventListener, { passive: false });
        document.addEventListener('touchend', stopDrag);
      }, { passive: true });

      divider.addEventListener('keydown', (e) => {
        const step = e.shiftKey ? 10 : 5;
        if (e.key === 'ArrowLeft') {
          applyPct(pct - step);
          e.preventDefault();
        }
        if (e.key === 'ArrowRight') {
          applyPct(pct + step);
          e.preventDefault();
        }
      });
    }
  }
</script>
