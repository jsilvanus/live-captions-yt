---
import Base from '../layouts/Base.astro';
---
<Base title="LCYT — Live Captions for YouTube">
  <div class="landing-page">
    <section class="hero">
      <h1>LCYT</h1>
      <p>Live Captions for YouTube — send real-time captions to your live streams via Google's HTTP POST caption ingestion API.</p>
    </section>

    <!-- Speech bubble: graphical depiction + bilingual vertical divider -->
    <div class="speech-bubble-wrap">
      <div class="speech-bubble">
        <div class="caption-bars" aria-hidden="true">
          <div class="caption-bar caption-bar--wide"></div>
          <div class="caption-bar caption-bar--medium"></div>
          <div class="caption-bar caption-bar--narrow"></div>
        </div>
        <!-- Split view: English left | draggable bar | Finnish right -->
        <div class="sb-split" role="group" aria-label="Language comparison — drag the handle to reveal more of either language">
          <div class="sb-panel sb-panel--en" aria-label="English">
            <div class="sb-panel__content">
              <span class="sb-lang-tag">EN&nbsp;🇬🇧</span>
              <p>LCYT makes live broadcasts accessible to everyone — send real-time captions in any language to your YouTube stream, breaking the language barrier for global audiences.</p>
            </div>
          </div>
          <div class="sb-divider" role="separator" tabindex="0"
               aria-label="Drag left or right to compare languages"
               aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" aria-valuetext="50% English, 50% Finnish">
            <div class="sb-divider__line" aria-hidden="true"></div>
            <div class="sb-divider__handle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 7H1M1 7L3 5M1 7L3 9" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 7H13M13 7L11 5M13 7L11 9" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div class="sb-panel sb-panel--fi" aria-label="Finnish">
            <div class="sb-panel__content">
              <span class="sb-lang-tag">🇫🇮&nbsp;FI</span>
              <p>LCYT mahdollistaa suoralähetysten tekstityksen — elävät tekstitykset tekevät sisältösi saavutettavaksi kaikille katsojille ympäri maailmaa.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="cards-grid">
      <a class="card" href="/lib">
        <span class="card__emoji" aria-hidden="true">📦</span>
        <div class="card__body">
          <h2>Library</h2>
          <p>JavaScript &amp; Python SDKs for sending captions directly or via the relay backend.</p>
        </div>
      </a>
      <a class="card" href="/api">
        <span class="card__emoji" aria-hidden="true">🔌</span>
        <div class="card__body">
          <h2>API</h2>
          <p>HTTP relay backend API reference — sessions, captions, keys, stats, and more.</p>
        </div>
      </a>
      <a class="card" href="/mcp">
        <span class="card__emoji" aria-hidden="true">🤖</span>
        <div class="card__body">
          <h2>MCP</h2>
          <p>Model Context Protocol server — integrate LCYT with AI assistants like Claude.</p>
        </div>
      </a>
      <a class="card" href="/guide">
        <span class="card__emoji" aria-hidden="true">📖</span>
        <div class="card__body">
          <h2>Guide</h2>
          <p>Step-by-step guide for the web app — setup, captions, translation, and shortcuts.</p>
        </div>
      </a>
      <a class="card" href="/blog">
        <span class="card__emoji" aria-hidden="true">📝</span>
        <div class="card__body">
          <h2>Blog</h2>
          <p>Updates, tutorials, and tips from the LCYT team.</p>
        </div>
      </a>
      <a class="card" href="/app">
        <span class="card__emoji" aria-hidden="true">🚀</span>
        <div class="card__body">
          <h2>App</h2>
          <p>Get an API key and launch the browser-based captioning app.</p>
        </div>
      </a>
      <a class="card card--repo" href="https://github.com/jsilvanus/live-captions-yt" target="_blank" rel="noopener noreferrer">
        <span class="card__emoji" aria-hidden="true">⭐</span>
        <div class="card__body">
          <h2>GitHub</h2>
          <p>View the source code, open issues, and contribute on GitHub.</p>
        </div>
      </a>
    </div>
  </div>
</Base>

<script>
  const container = document.querySelector<HTMLElement>('.sb-split');
  const divider   = document.querySelector<HTMLElement>('.sb-divider');
  const panelEn   = document.querySelector<HTMLElement>('.sb-panel--en');
  const panelFi   = document.querySelector<HTMLElement>('.sb-panel--fi');

  if (container && divider && panelEn && panelFi) {
    // Initial 50 / 50 split — panels keep their full size; only visibility changes
    let pct = 50;

    function applyPct(p: number) {
      pct = Math.max(0, Math.min(100, p));
      // Clip each panel so EN is visible on the left, FI on the right
      panelEn.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
      panelFi.style.clipPath = `inset(0 0 0 ${pct}%)`;
      // Move the divider handle to match the clip boundary
      divider.style.left = `${pct}%`;
      const enPct = Math.round(pct);
      divider.setAttribute('aria-valuenow', String(enPct));
      divider.setAttribute('aria-valuetext', `${enPct}% English, ${100 - enPct}% Finnish`);
    }

    applyPct(50);

    let dragging = false;

    function getClientX(e: MouseEvent | TouchEvent): number {
      const touches = (e as TouchEvent).touches;
      return touches ? touches[0].clientX : (e as MouseEvent).clientX;
    }

    function onMove(e: MouseEvent | TouchEvent) {
      if (!dragging) return;
      e.preventDefault();
      const rect = container.getBoundingClientRect();
      const x = getClientX(e) - rect.left;
      applyPct((x / rect.width) * 100);
    }

    function stopDrag() {
      dragging = false;
      document.removeEventListener('mousemove', onMove as EventListener);
      document.removeEventListener('mouseup', stopDrag);
      document.removeEventListener('touchmove', onMove as EventListener);
      document.removeEventListener('touchend', stopDrag);
    }

    divider.addEventListener('mousedown', (e) => {
      e.preventDefault();
      dragging = true;
      document.addEventListener('mousemove', onMove as EventListener);
      document.addEventListener('mouseup', stopDrag);
    });

    divider.addEventListener('touchstart', (e) => {
      dragging = true;
      document.addEventListener('touchmove', onMove as EventListener, { passive: false });
      document.addEventListener('touchend', stopDrag);
    }, { passive: true });

    // Keyboard support: arrow keys nudge the divider (Shift for 10% jumps)
    divider.addEventListener('keydown', (e) => {
      const step = e.shiftKey ? 10 : 5;
      if (e.key === 'ArrowLeft')  { applyPct(pct - step); e.preventDefault(); }
      if (e.key === 'ArrowRight') { applyPct(pct + step); e.preventDefault(); }
    });
  }
</script>
