---
import Base from '../../layouts/Base.astro';
const title = 'Embed Example — Sent Log (read-only)';
---
<head>
  <meta name="robots" content="noindex" />
</head>
<Base title={title}>
  <h1>Sent log embed example (read-only)</h1>
  <p>Live preview (no credentials required):</p>
  <iframe src="https://app.lcyt.fi/embed/sentlog" style="width:100%;height:420px;border:1px solid #ccc"></iframe>
  <h2>Embed code</h2>
  <pre><code>&lt;iframe src="https://app.lcyt.fi/embed/sentlog" width="560" height="420"&gt;&lt;/iframe&gt;</code></pre>
</Base>
