---
import Base from '../../layouts/Base.astro';
const title = 'Embed Example — Files Manager';
---
<head>
  <meta name="robots" content="noindex" />
</head>
<Base title={title}>
  <h1>Files manager embed example</h1>
  <p>Live preview (replace <code>your-lcyt-host</code>, <code>server</code> and <code>apikey</code>):</p>
  <iframe src="https://app.lcyt.fi/embed/files?server=https://api.lcyt.fi&apikey=YOUR_KEY" style="width:100%;height:640px;border:1px solid #ccc"></iframe>
  <h2>Embed code</h2>
  <pre><code>&lt;iframe src="https://app.lcyt.fi/embed/files?server=https://api.lcyt.fi&amp;apikey=YOUR_KEY" width="800" height="640"&gt;&lt;/iframe&gt;</code></pre>
</Base>
