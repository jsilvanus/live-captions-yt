---
import Base from '../../layouts/Base.astro';
const title = 'Embed Example — File Drop';
---
<head>
  <meta name="robots" content="noindex" />
</head>
<Base title={title}>
  <h1>File drop embed example</h1>
  <p>Live preview (replace <code>your-lcyt-host</code>, <code>server</code> and <code>apikey</code>):</p>
  <iframe src="https://your-lcyt-host/embed/file-drop?server=https://api.example.com&apikey=YOUR_KEY" style="width:100%;height:420px;border:1px solid #ccc"></iframe>
  <h2>Embed code</h2>
  <pre><code>&lt;iframe src="https://your-lcyt-host/embed/file-drop?server=https://api.example.com&amp;apikey=YOUR_KEY" width="560" height="420"&gt;&lt;/iframe&gt;</code></pre>
</Base>
