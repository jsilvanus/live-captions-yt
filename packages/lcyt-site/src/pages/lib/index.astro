---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

const LICENSE_ORDER = ['license'];
const JS_ORDER = ['README', 'sender', 'backend-sender', 'config', 'logger', 'errors'];
const PY_ORDER = [
  'python/README', 'python/sender', 'python/backend-sender',
  'python/config', 'python/errors',
];

function docLabel(id: string, title?: string): string {
  if (title) return title;
  if (id === 'README' || id === 'python/README') return 'Overview';
  const name = id.includes('/') ? id.split('/').pop()! : id;
  return name.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const allDocs = await getCollection('lib');

const licenseDocs = LICENSE_ORDER.map(id => allDocs.find(d => d.id === id)).filter(Boolean) as typeof allDocs;
const jsDocs = JS_ORDER.map(id => allDocs.find(d => d.id === id)).filter(Boolean) as typeof allDocs;
const pyDocs = PY_ORDER.map(id => allDocs.find(d => d.id === id)).filter(Boolean) as typeof allDocs;

const docs = [...licenseDocs, ...jsDocs, ...pyDocs];

const rendered = await Promise.all(docs.map(doc => render(doc)));
---
<GuideLayout
  title="Library"
  description="JavaScript and Python SDKs for sending live captions to YouTube via the LCYT API."
>
  <Fragment slot="sidebar">
    <div style="padding-left: 0.5rem;">
      <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem;">Library</p>

      {licenseDocs.length > 0 && (
        <>
          <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; margin-top: 0.5rem;">License</p>
          <ul style="list-style: none; margin-bottom: 1rem;">
            {licenseDocs.map(doc => (
              <li><a href={`#${doc.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{docLabel(doc.id, doc.data.title)}</a></li>
            ))}
          </ul>
        </>
      )}

      {jsDocs.length > 0 && (
        <>
          <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem;">Node.js</p>
          <ul style="list-style: none; margin-bottom: 1rem;">
            {jsDocs.map(doc => (
              <li><a href={`#${doc.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{docLabel(doc.id, doc.data.title)}</a></li>
            ))}
          </ul>
        </>
      )}

      {pyDocs.length > 0 && (
        <>
          <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem;">Python</p>
          <ul style="list-style: none;">
            {pyDocs.map(doc => (
              <li><a href={`#${doc.id}`} style="display: block; padding: 0.3rem 0.5rem; font-size: 0.84rem; color: var(--muted); border-radius: 6px; transition: all 0.12s; text-decoration: none;">{docLabel(doc.id, doc.data.title)}</a></li>
            ))}
          </ul>
        </>
      )}
    </div>
  </Fragment>

  {docs.map((doc, i) => {
    const { Content } = rendered[i];
    return (
      <section id={doc.id.replace(/\//g, '-')}>
        <Content />
      </section>
    );
  })}
</GuideLayout>
