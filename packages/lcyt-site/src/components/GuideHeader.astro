---
/* Guide page header with introduction and quick navigation */
export interface Props {
  title: string;
  subtitle?: string;
  estimatedTime?: string;
  sections: Array<{ id: string; label: string }>;
  class?: string;
}

const { title, subtitle, estimatedTime, sections, class: className } = Astro.props;
---

<header class={`guide-header ${className || ''}`}>
  <h1 class="guide-header__title">{title}</h1>
  {subtitle && <p class="guide-header__subtitle">{subtitle}</p>}

  <div class="guide-header__meta">
    {estimatedTime && (
      <div class="guide-header__meta-item">
        <span class="guide-header__meta-icon">⏱️</span>
        <span>{estimatedTime}</span>
      </div>
    )}
  </div>

  {sections.length > 0 && (
    <nav class="guide-header__toc">
      <p class="guide-header__toc-title">Jump to:</p>
      <ul class="guide-header__toc-list">
        {sections.map(section => (
          <li>
            <a href={`#${section.id}`}>{section.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  )}
</header>

<style>
  .guide-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .guide-header__title {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    line-height: var(--line-height-tight);
  }

  .guide-header__subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    line-height: var(--line-height-normal);
  }

  .guide-header__meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .guide-header__meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .guide-header__meta-icon {
    font-size: 1.2rem;
  }

  .guide-header__toc {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin-top: 1.5rem;
  }

  .guide-header__toc-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .guide-header__toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.5rem;
  }

  .guide-header__toc-list li {
    margin: 0;
  }

  .guide-header__toc-list a {
    display: block;
    padding: 0.4rem 0;
    color: var(--color-primary);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .guide-header__toc-list a:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }
</style>
