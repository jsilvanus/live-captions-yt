---
import Base from './Base.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Base title={title}>
  <div class="guide-layout">
    <!-- ── HEADER ──────────────────────────────────────────────────────── -->
    <div class="guide-header">
      <div class="guide-header-content">
        <p class="guide-header-tag">Documentation</p>
        <h1 class="guide-header-title">{title}</h1>
        {description && <p class="guide-header-desc">{description}</p>}
      </div>
    </div>

    <!-- ── SIDEBAR ─────────────────────────────────────────────────────── -->
    <aside class="guide-sidebar">
      <slot name="sidebar" />
    </aside>

    <!-- ── MAIN CONTENT ────────────────────────────────────────────────── -->
    <main class="guide-content">
      <div class="prose">
        <slot />
      </div>
    </main>
  </div>
</Base>

<style>
  .guide-layout {
    display: flex;
    min-height: calc(100vh - var(--nav-height));
  }

  .guide-header {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    z-index: 40;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 2rem 3rem;
  }

  .guide-header-content {
    max-width: 1100px;
    margin: 0 auto;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .guide-header-tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .guide-header-title {
    font-family: var(--ff-serif);
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--text);
  }

  .guide-header-desc {
    font-size: 0.95rem;
    color: var(--muted);
    font-weight: 300;
    margin-top: 0.75rem;
    max-width: 500px;
    line-height: 1.65;
  }

  .guide-sidebar {
    position: fixed;
    top: calc(var(--nav-height) + 200px);
    left: 0;
    width: var(--sidebar-width);
    max-height: calc(100vh - var(--nav-height) - 200px);
    overflow-y: auto;
    padding: 2rem 1.25rem;
    border-right: 1px solid var(--border);
    background: var(--bg);
  }

  .guide-content {
    margin-left: var(--sidebar-width);
    margin-top: 200px;
    flex: 1;
    min-width: 0;
    padding: 3.5rem 4rem 6rem;
    max-width: 760px;
  }

  /* Prose styles */
  .prose h1 {
    font-family: var(--ff-serif);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .prose h1:first-child {
    margin-top: 0;
  }

  .prose h2 {
    font-family: var(--ff-sans);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .prose h3 {
    font-family: var(--ff-sans);
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .prose h4 {
    font-family: var(--ff-sans);
    font-size: 0.9rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.4rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .prose p {
    font-size: 0.9375rem;
    color: #463d38;
    line-height: 1.75;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose li {
    font-size: 0.9375rem;
    color: #463d38;
    line-height: 1.7;
    margin-bottom: 0.3rem;
    font-weight: 300;
  }

  .prose strong {
    font-weight: 600;
    color: var(--text);
  }

  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose a:hover {
    opacity: 0.8;
  }

  .prose code {
    font-family: var(--ff-mono);
    font-size: 0.82em;
    background: #e8e6e1;
    color: #463d38;
    padding: 0.12em 0.4em;
    border-radius: 4px;
  }

  .prose pre {
    background: #13121a;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.25rem 0;
    border: 1px solid #2a282f;
  }

  .prose pre code {
    background: none;
    color: #e8e6e1;
    font-size: 0.82rem;
    padding: 0;
  }

  .prose blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1.25rem;
    margin: 1.25rem 0;
    background: var(--accent-lt);
    border-radius: 0 8px 8px 0;
  }

  .prose blockquote p {
    color: var(--text);
    margin: 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.875rem;
  }

  .prose th {
    background: var(--surface);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.6rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .prose td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  @media (max-width: 900px) {
    .guide-sidebar {
      position: static;
      top: auto;
      width: 100%;
      max-height: auto;
      overflow-y: visible;
      padding: 1.5rem 1rem;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    .guide-content {
      margin-left: 0;
      margin-top: 0;
      padding: 1.5rem 1rem;
    }

    .guide-header {
      position: static;
      margin-bottom: 0;
    }

    .prose h1 {
      font-size: 1.75rem;
    }
  }
</style>
