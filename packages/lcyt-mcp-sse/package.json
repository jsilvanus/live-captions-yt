{
  "name": "lcyt-mcp-sse",
  "version": "0.1.0",
  "description": "MCP server for sending live captions to YouTube Live streams (HTTP SSE transport)",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "lcyt-mcp-sse": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "cross-env LCYT_WEB_URL=https://lcyt-test.example SPEECH_PUBLIC_URL=https://mcp-test.example node --test test/*.test.js"
  },
  "keywords": [
    "youtube",
    "live",
    "captions",
    "mcp",
    "model-context-protocol",
    "sse"
  ],
  "author": "jsilvanus",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0",
    "express": "^4.18.0",
    "lcyt": "*",
    "lcyt-backend": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jsilvanus/live-captions-yt.git",
    "directory": "packages/lcyt-mcp-sse"
  },
  "bugs": {
    "url": "https://github.com/jsilvanus/live-captions-yt/issues"
  },
  "homepage": "https://github.com/jsilvanus/live-captions-yt#readme"
}
