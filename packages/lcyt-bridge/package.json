{
  "name": "lcyt-bridge",
  "version": "0.1.0",
  "description": "LCYT bridge agent — relays production control commands to AMX and Roland over TCP",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "lcyt-bridge": "src/index.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "start": "node src/index.js",
    "build:win": "npx @yao-pkg/pkg . --target node18-win-x64 --output dist/lcyt-bridge.exe",
    "build:mac": "npx @yao-pkg/pkg . --target node18-macos-x64 --output dist/lcyt-bridge-mac",
    "build:linux": "npx @yao-pkg/pkg . --target node18-linux-x64 --output dist/lcyt-bridge-linux"
  },
  "pkg": {
    "assets": [],
    "scripts": []
  },
  "dependencies": {
    "atem-connection": "^2.0.0",
    "dotenv": "^16.0.0",
    "eventsource": "^2.0.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Juha Itäleino <jsilvanus@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsilvanus/live-captions-yt.git",
    "directory": "packages/lcyt-bridge"
  }
}
